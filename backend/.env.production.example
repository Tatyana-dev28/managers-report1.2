APP_NAME="Ежедневный отчет менеджера"
ENVIRONMENT=production
DEMO_MODE=false

DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DB_NAME?charset=utf8mb4
STORAGE_BACKEND=mysql

TIMEZONE=Europe/Moscow
MORNING_REMINDER_TIME=09:00
AFTERNOON_REMINDER_TIME=13:00
EVENING_REMINDER_TIME=17:00
REMINDERS_ENABLED=false

FRONTEND_APP_URL=https://frontend-domain.example
CORS_ORIGINS=["https://frontend-domain.example"]

SYSTEM_METRICS_AUTO_COLLECT_ENABLED=true
SYSTEM_METRICS_COLLECT_INTERVAL_MINUTES=60

BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/

BITRIX_MEETING_ENTITY_TYPE_ID=1070
BITRIX_CONTRACT_ENTITY_TYPE_ID=170
BITRIX_INVOICE_ENTITY_TYPE_ID=31

BITRIX_COLD_BASE_DEAL_CATEGORY_ID=57
BITRIX_SALE_DEAL_CATEGORY_ID=0
BITRIX_SALE_SUCCESS_STAGE_ID=WON

BITRIX_MEETING_HELD_STAGE_IDS=DT1070_87:SUCCESS

BITRIX_CONTRACT_SENT_STAGE_ID=DT170_17:CLIENT
BITRIX_CONTRACT_SIGNED_STAGE_ID=DT170_17:UC_DL8B18

BITRIX_INVOICE_SENT_STAGE_ID=DT31_1:S
BITRIX_INVOICE_PAID_STAGE_ID=DT31_1:UC_GQECS8
